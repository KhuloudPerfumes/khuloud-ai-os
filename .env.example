ENVIRONMENT=local
NEXT_PUBLIC_DEPLOYMENT_MODE=local

POSTGRES_DB=khuloud_ai_os
POSTGRES_USER=khuloud
POSTGRES_PASSWORD=khuloud
DATABASE_URL=postgresql+psycopg://khuloud:khuloud@postgres:5432/khuloud_ai_os

REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
PRODUCT_SOURCE_URL=https://khuloudperfumes.com
KHULOUD_PRODUCT_SOURCE_URL=https://khuloudperfumes.com
IMAGE_GENERATION_PROVIDER=auto
# Optional Nano Banana/Gemini API mode. Requires a Google AI Studio/Gemini API key; Gemini app Pro login alone is not an API key.
GEMINI_API_KEY=

API_BASE_URL=http://backend:8000
FRONTEND_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Cloud mode examples:
# ENVIRONMENT=cloud-free
# NEXT_PUBLIC_DEPLOYMENT_MODE=cloud-free
# NEXT_PUBLIC_API_BASE_URL=https://your-khuloud-backend.onrender.com
# DATABASE_URL=postgresql+psycopg://postgres:[password]@[supabase-host]:5432/postgres
# REDIS_URL=
# QDRANT_URL=
# OLLAMA_BASE_URL=
# PRODUCT_SOURCE_URL=https://khuloudperfumes.com
# KHULOUD_PRODUCT_SOURCE_URL=https://khuloudperfumes.com
# IMAGE_GENERATION_PROVIDER=auto
# GEMINI_API_KEY=

LOCAL_AUTH_USERNAME=founder
LOCAL_AUTH_PASSWORD=change-me
SHOPIFY_WEBHOOK_SECRET=change-me

FOUNDER_EMAIL=founder@khuloud.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
